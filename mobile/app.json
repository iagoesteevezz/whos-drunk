{
  "expo": {
    "name": "Who's Drunk",
    "slug": "whosdrunk",
    "scheme": "whosdrunk",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.whosdrunk.mobile"
    },
    "android": {
      "package": "app.whosdrunk.mobile"
    }
  }
}
