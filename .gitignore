# ───────────────────────────────────────────────────────────
# Root .gitignore — OS / editor cruft + global env safety net.
# Build artifacts are handled per subproject:
#   backend/.gitignore  (Maven / Java)
#   mobile/.gitignore   (Expo / Node)
# ───────────────────────────────────────────────────────────

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors / IDEs
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# Logs
*.log

# Dependencies / build output (global safety net; also covered per subproject)
node_modules/
target/

# Environment files — never commit secrets.
.env
.env.*
!.env.example
